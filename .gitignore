# Summary: specifies files & dirs that git shouldn't track.

# Bazel files.
/bazel-*

# Jupyter-specific items.
.ipynb_checkpoints
ipython_config.py
jupyter_kernel.lock

# Python-related items.
*$py.class
*.cover
*.coverage
*.coverage.*
*.egg
*.egg-info/
*.py,cover
*.py[cod]
*.whl
.cache/
.dmypy.json
.mypy_cache/
.nox/
.pytest_cache/
.python-version
.pytype/
.ruff_cache/
.tox/
__pycache__/
build/
coverage.xml
dist/
dmypy.json
poetry.lock
sdist/
venv/
wheelhouse/

# Don't commit local PyPI config files.
.pypirc

# From pytest-benchmark.
*.benchmarks/

# Default pycharm virtual env.
.venv/

# Generated C/C++ files and libraries.
*.a
*.mod
*.o
*.so
*.x

# macOS directory metadata files.
*.DS_Store

# Common editor backup files and temp files.
**/*.iml
*.bak
*.log
*.swp
*.tmp
*.~*~
*~
.\#*
.idea/
.vs
.vscode/
\#*\#

# Sphinx.
_build
docs/generated

# Ignore file generated by dev_tools/write-ci-requirements.py
ci-requirements.txt
